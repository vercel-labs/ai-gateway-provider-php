{
    "name": "vercel-labs/ai-gateway-provider",
    "version": "1.0.0",
    "description": "Vercel AI Gateway provider for the PHP AI Client SDK. Works as a Composer package and WordPress plugin.",
    "license": "MIT",
    "keywords": [
        "ai",
        "gateway",
        "vercel",
        "wordpress",
        "llm"
    ],
    "authors": [
        {
            "name": "Vercel",
            "homepage": "https://vercel.com"
        }
    ],
    "homepage": "https://github.com/vercel-labs/ai-gateway-provider-php",
    "support": {
        "issues": "https://github.com/vercel-labs/ai-gateway-provider-php/issues",
        "source": "https://github.com/vercel-labs/ai-gateway-provider-php"
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "felixarntz/terminal-image": "^1.0",
        "guzzlehttp/guzzle": "^7.0",
        "phpcompatibility/php-compatibility": "dev-develop",
        "phpstan/phpstan": "~2.1",
        "phpunit/phpunit": "^9.5",
        "slevomat/coding-standard": "^8.20",
        "squizlabs/php_codesniffer": "^3.7 || ^4.0",
        "symfony/dotenv": "^5.4",
        "wordpress/php-ai-client": "^1.3"
    },
    "suggest": {
        "wordpress/php-ai-client": "Required. The core PHP AI Client SDK that this provider extends."
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Vercel\\AiGatewayProvider\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vercel\\AiGatewayProvider\\Tests\\Mocks\\": "tests/Mocks/",
            "Vercel\\AiGatewayProvider\\Tests\\Traits\\": "tests/Traits/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true
        },
        "optimize-autoloader": true,
        "platform": {
            "php": "7.4"
        },
        "sort-packages": true
    },
    "scripts": {
        "check:versions": "php tools/check-versions.php",
        "phpcbf": "phpcbf",
        "phpcs": "phpcs",
        "phpstan": "phpstan analyze --memory-limit=256M",
        "test": "@test:unit",
        "test:unit": "phpunit",
        "test:integration": [
            "@putenv COMPOSER_PROCESS_TIMEOUT=600",
            "phpunit --configuration phpunit-integration.xml.dist"
        ],
        "update:since": "npx @felixarntz/wp-plugins-cli update-since . --version $(composer config version)"
    }
}
